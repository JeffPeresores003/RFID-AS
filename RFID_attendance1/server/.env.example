SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_KEY=your-supabase-key

# Optional admin session lifetime in hours
ADMIN_SESSION_HOURS=8

# Optional scanner bridge key.
# If set, POST /api/test-scan requires x-scanner-bridge-key to match.
SCANNER_BRIDGE_KEY=

# Local scanner bridge settings (used by `npm run bridge` on the USB-connected machine)
BRIDGE_API_BASE=https://rfid-as.onrender.com/api
BRIDGE_ARDUINO_PORT=
BRIDGE_BAUD_RATE=9600
BRIDGE_FORWARD_DEBOUNCE_MS=2500
BRIDGE_RECONNECT_DELAY_MS=1500
